+_DESTRUCTIVE_PATTERNS = [
+    ("rm", "rm -rf 刪除防護"),
+    ("force", "git push --force 防護"),
+    ("reset --hard", "git reset --hard 防護"),
+    ("drop", "DROP TABLE 防護"),
+    ("alembic", "DB migration 防護"),
+]
+
+# 過寬授權的萬用字元模式
+_WILDCARD_PATTERNS = ["Bash(*)", "Bash(bash*)", "*"]
