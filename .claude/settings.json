{
  "attribution": {
    "sessionUrl": false
  },
  "fallbackModel": [
    "claude-sonnet-4-6",
    "claude-haiku-4-5"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "async": true,
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/post-edit-mypy.sh",
            "statusMessage": "mypy 型別檢查...",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_FILE_PATH\" == *.md ]]; then npx markdownlint-cli2 --fix \"$CLAUDE_FILE_PATH\" >&2 || true; fi",
            "statusMessage": "markdownlint auto-fix..."
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-compact-handover.sh",
            "statusMessage": "PreCompact handover 提醒...",
            "timeout": 15,
            "type": "command"
          }
        ],
        "matcher": "auto"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/protect-push.sh || exit 2",
            "statusMessage": "檢查 git push 安全性...",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-push-tree-drift-guard.py || exit 2",
            "statusMessage": "檢查 push 的樹是否與已驗證的樹一致...",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "[ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-push-ruff-format-guard.py\" ] || exit 0; python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-push-ruff-format-guard.py\" || exit 2",
            "statusMessage": "檢查 push 出去的 .py 是否已 ruff format...",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/bash-ap2-check.py || exit 2",
            "statusMessage": "AP2 Unicode 字元檢查...",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-commit.sh",
            "statusMessage": "pre-commit: markdownlint + ruff format...",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/bash-ap1-inline-check.sh || exit 2",
            "statusMessage": "AP1 inline Python / osascript 檢查...",
            "timeout": 15,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/protect-worktree.py || exit 2",
            "statusMessage": "Worktree branch 安全檢查...",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash|EnterWorktree"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/post-compact-handover-back.sh",
            "statusMessage": "SessionStart handover-back 提醒...",
            "timeout": 15,
            "type": "command"
          }
        ],
        "matcher": "compact|clear"
      }
    ]
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)"
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  }
}
