{
  "worktree": {
    "baseRef": "fresh"
  },
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/.claude/hooks/pre-compact-handover.sh",
            "statusMessage": "PreCompact handover 提醒...",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact|clear",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/.claude/hooks/post-compact-handover-back.sh",
            "statusMessage": "SessionStart handover-back 提醒...",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/.claude/hooks/post-edit-mypy.sh",
            "statusMessage": "mypy 型別檢查...",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "\"$(git rev-parse --show-toplevel)\"/.claude/hooks/protect-push.sh || exit 2",
            "type": "command",
            "statusMessage": "檢查 git push 安全性..."
          }
        ],
        "matcher": "Bash"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)\"/.claude/hooks/bash-ap2-check.py || exit 2",
            "statusMessage": "AP2 Unicode 字元檢查...",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/.claude/hooks/markdownlint-pre-commit.sh",
            "statusMessage": "markdownlint 檢查 staged .md 檔...",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)\"/.claude/hooks/bash-ap1-inline-check.sh || exit 2",
            "statusMessage": "AP1 inline Python / osascript 檢查...",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash|EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)\"/.claude/hooks/protect-worktree.py || exit 2",
            "statusMessage": "Worktree branch 安全檢查...",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
