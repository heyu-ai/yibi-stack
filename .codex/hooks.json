{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/howie/Workspace/github/yibi-stack/.codex/hooks/protect-push.sh' || exit 2",
            "statusMessage": "檢查 git push 安全性..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 '/Users/howie/Workspace/github/yibi-stack/.codex/hooks/pre-push-tree-drift-guard.py' || exit 2",
            "timeout": 10,
            "statusMessage": "檢查 push 的樹是否與已驗證的樹一致..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 '/Users/howie/Workspace/github/yibi-stack/.codex/hooks/bash-ap2-check.py' || exit 2",
            "timeout": 10,
            "statusMessage": "AP2 Unicode 字元檢查..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/howie/Workspace/github/yibi-stack/.codex/hooks/pre-commit.sh'",
            "timeout": 30,
            "statusMessage": "pre-commit: markdownlint + ruff format..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/howie/Workspace/github/yibi-stack/.codex/hooks/bash-ap1-inline-check.sh' || exit 2",
            "timeout": 15,
            "statusMessage": "AP1 inline Python / osascript 檢查..."
          }
        ]
      },
      {
        "matcher": "Bash|EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "python3 '/Users/howie/Workspace/github/yibi-stack/.codex/hooks/protect-worktree.py' || exit 2",
            "timeout": 10,
            "statusMessage": "Worktree branch 安全檢查..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_FILE_PATH\" == *.md ]]; then npx markdownlint-cli2 --fix \"$CLAUDE_FILE_PATH\" >&2 || true; fi",
            "statusMessage": "markdownlint auto-fix..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/howie/Workspace/github/yibi-stack/.codex/hooks/pre-compact-handover.sh'",
            "timeout": 15,
            "statusMessage": "PreCompact handover 提醒..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact|clear",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/howie/Workspace/github/yibi-stack/.codex/hooks/post-compact-handover-back.sh'",
            "timeout": 15,
            "statusMessage": "SessionStart handover-back 提醒..."
          }
        ]
      }
    ]
  }
}
