#!/usr/bin/env bash
# Wrapper: 自動偵測 skill_repo + project，forward args 給 tasks.mycelium lessons
# Agent 端直接呼叫：~/.agents/bin/lessons add --type ... --key ... --insight "..." ...
# 不需要手動偵測 SKILL_REPO 或 PROJECT，不觸發 Claude Code bash anti-pattern 確認框
#
# --project 注入策略（讀寫不對稱，刻意為之）：
#   寫入（add）→ 注入 cwd 偵測到的 project。這是 load-bearing：issue #243 的 287 條
#     retro lesson 就是因為沒走 wrapper、cwd 被 `uv run --directory` 換成 yibi-stack
#     而被誤記。預設注入，未知/新增的子命令一律比照寫入處理（fail-safe：寧可多帶
#     scope，也不要讓新的寫入指令靜默記到錯的 project）。
#   讀取（show / search）→ 不注入。mycelium CLI 對這兩個子命令的 --project 預設是
#     「顯示全部 project」；wrapper 若注入，就靈默覆寫了 CLI 文件宣稱的預設，讓呼叫端
#     以為拿到跨 project 結果、實際只拿到 cwd 那個 repo 的，且無任何訊號。
set -euo pipefail

if ! SKILL_REPO=$("$HOME/.agents/bin/resolve-skill-repo"); then echo '[FAIL] 無法解析 skill repo，請在 yibi-stack 目錄執行 make install' >&2; exit 1; fi

# 子命令為第一個位置引數（如 `lessons show --json`）
SUBCMD="${1:-}"

# 讀取指令：保留 CLI 自身的「預設全部 project」語意，不注入
case "$SUBCMD" in
  show|search) exec uv run --directory "$SKILL_REPO" python -m tasks.mycelium lessons "$@" ;;
esac

# 自動偵測 project（若 caller 已用 --project 指定則跳過，避免重複）
# token-based check 支援 --project=val 形式，避免 insight 內文含 --project 的 false positive
has_project=0
for arg in "$@"; do
  case "$arg" in
    --project|--project=*) has_project=1; break ;;
  esac
done

if [ "$has_project" -eq 0 ]; then
  if GIT_COMMON=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null); then
    PROJECT=$(basename "$(dirname "$GIT_COMMON")")
  else
    PROJECT=$(basename "$(pwd)")
  fi
  exec uv run --directory "$SKILL_REPO" python -m tasks.mycelium lessons "$@" --project "$PROJECT"
else
  exec uv run --directory "$SKILL_REPO" python -m tasks.mycelium lessons "$@"
fi
